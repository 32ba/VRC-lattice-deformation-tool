msgid "net.32ba.lattice-deformation-tool.localization.flip-layer-y"
msgstr "Flip Layer Y"

msgid "net.32ba.lattice-deformation-tool.localization.flip-layer-y.tooltip"
msgstr "Swaps deformation between mirrored vertex pairs on Y."

msgid "net.32ba.lattice-deformation-tool.localization.flip-layer-z"
msgstr "Flip Layer Z"

msgid "net.32ba.lattice-deformation-tool.localization.flip-layer-z.tooltip"
msgstr "Swaps deformation between mirrored vertex pairs on Z."

